DATABASE_URL=postgres://user:password@localhost:5432/posecommerce
JWT_SECRET=your-secret-key-here-change-in-production

# ── PostgreSQL (used by docker compose) ─────────────────────
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=posecommerce

# ── Connection Pool ──────────────────────────────────────────
DB_MAX_CONNECTIONS=50
DB_MIN_CONNECTIONS=5
DB_ACQUIRE_TIMEOUT_SECS=5
DB_IDLE_TIMEOUT_SECS=300
DB_MAX_LIFETIME_SECS=1800

# ── CORS ────────────────────────────────────────────────────
# Comma-separated list of allowed origins. If unset, all origins are allowed.
# CORS_ALLOWED_ORIGINS=http://localhost:3000,https://myapp.example.com

# ── Background Jobs ─────────────────────────────────────────
RESERVATION_EXPIRY_INTERVAL_SECS=300
CART_CLEANUP_INTERVAL_SECS=900